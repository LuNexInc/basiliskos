{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Basiliskos",
  "version": "1.1.16",
  "identifier": "com.threereadylab.hydragateway",
  "build": {
    "beforeDevCommand": "pnpm prepare:gateway && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm prepare:gateway && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Basiliskos",
        "width": 920,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "visible": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; form-action 'none'; img-src 'self' asset: data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["nsis"],
    "publisher": "3Ready Prototyping Lab",
    "resources": [
      "resources/gateway/*",
      "resources/icons/claude-window-black.ico",
      "resources/icons/claude-tray-inverted.ico"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "signCommand": {
        "cmd": "powershell",
        "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "../scripts/sign-command.ps1", "%1"]
      },
      "nsis": {
        "installMode": "perMachine",
        "startMenuFolder": "3ReadyLab",
        "installerHooks": "./windows/installer-hooks.nsh"
      }
    }
  }
}
